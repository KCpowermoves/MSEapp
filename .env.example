# Service account credentials from the JSON key file you downloaded
GOOGLE_SERVICE_ACCOUNT_EMAIL=mse-field-app@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...replace-me...\n-----END PRIVATE KEY-----\n"

# Google Sheet that the app reads/writes (must be shared with the service account email)
GOOGLE_SHEET_ID=

# Top-level Drive folder where all job photos live (must be shared with the service account email)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Random 32+ char string. Generate one: openssl rand -base64 32
IRON_SESSION_PASSWORD=

# Public URL of the app (for PWA + redirect handling). Local default is fine.
APP_URL=http://localhost:3000
