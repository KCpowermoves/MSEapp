# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# e2e test artifacts
/e2e-screenshots

# engineering calculator: source Excel workbook stays local-only since
# it may carry real customer numbers. Inspector dumps stay local by
# default too — promote individually once sanitized.
/engineering/*.xlsx
/engineering/*.xlsm
/engineering/*.dump.md
/engineering/*.dump.json

# EXCEPTION: the runtime templates ship with the deploy.
!/engineering/template-BWI.xlsx
!/engineering/template-Andrews.xlsx
.env*
